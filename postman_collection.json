{
  "info": {
    "name": "Lost & Found Item Management System",
    "_postman_id": "c3cfba52-6e53-4e38-8b05-7b8426fa4ea9",
    "description": "API collection for Lost & Found MERN project.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Register User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Aman Sharma\",\n  \"email\": \"aman@example.com\",\n  \"password\": \"123456\"\n}"
        },
        "url": "{{baseUrl}}/register"
      }
    },
    {
      "name": "Login User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"aman@example.com\",\n  \"password\": \"123456\"\n}"
        },
        "url": "{{baseUrl}}/login"
      }
    },
    {
      "name": "Get Dashboard",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/dashboard"
      }
    },
    {
      "name": "Add Item",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"itemName\": \"Black Wallet\",\n  \"description\": \"Wallet lost near library block\",\n  \"type\": \"Lost\",\n  \"category\": \"Accessories\",\n  \"location\": \"Central Library\",\n  \"date\": \"2026-04-23\",\n  \"contactInfo\": \"+91-9876543210\"\n}"
        },
        "url": "{{baseUrl}}/items"
      }
    },
    {
      "name": "Get All Items",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/items"
      }
    },
    {
      "name": "Get Item By ID",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/items/{{itemId}}"
      }
    },
    {
      "name": "Update Item",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"itemName\": \"Black Wallet\",\n  \"description\": \"Wallet updated after checking classroom area\",\n  \"type\": \"Lost\",\n  \"category\": \"Accessories\",\n  \"location\": \"Classroom B-204\",\n  \"date\": \"2026-04-23\",\n  \"contactInfo\": \"+91-9876543210\"\n}"
        },
        "url": "{{baseUrl}}/items/{{itemId}}"
      }
    },
    {
      "name": "Delete Item",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/items/{{itemId}}"
      }
    },
    {
      "name": "Search Item",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/items/search?name=wallet&category=Accessories"
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "itemId",
      "value": ""
    }
  ]
}
